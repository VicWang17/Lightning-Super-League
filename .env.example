# ============================================
# Lightning Super League - 环境配置示例
# 复制本文件为 .env 并修改为你的本地端口
# ============================================

# --- 端口配置 (如果端口冲突请修改) ---
# 注意：修改端口后，下方对应 URL 中的端口也要同步修改
DB_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- 应用配置 ---
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# --- 数据库 ---
# 若 DB_PORT 修改，请同步修改下方 DATABASE_URL 中的端口
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=lightning_league
MYSQL_USER=lightning
MYSQL_PASSWORD=lightning_pass
DATABASE_URL=mysql+asyncmy://lightning:lightning_pass@localhost:3306/lightning_league

# --- Redis ---
# 若 REDIS_PORT 修改，请同步修改下方 REDIS_URL 中的端口
REDIS_URL=redis://localhost:6379/0

# --- 前端 API 地址 ---
# 若 BACKEND_PORT 修改，请同步修改下方地址
VITE_API_URL=http://localhost:8000/api/v1

# --- CORS 配置 (逗号分隔) ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Go 比赛引擎 ---
MATCH_ENGINE_URL=http://localhost:8080
MATCH_ENGINE_API_KEY=
